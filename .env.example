# Homepage Dashboard Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to git!

# ---------- Host validation (required) ----------
# Add the exact address:port you use to access the dashboard
HOMEPAGE_ALLOWED_HOSTS=localhost:

# ---------- Service URLs (for links) ----------
# These are the addresses you click on in the dashboard
HOMEPAGE_VAR_UPTIME_URL=
HOMEPAGE_VAR_GLANCES_URL=
HOMEPAGE_VAR_GRAFANA_URL=

# ---------- Widget API endpoints (internal container names) ----------
# Used by the dashboard to fetch data (Glances, etc.)
HOMEPAGE_VAR_GLANCES_API=

# ---------- Optional: future widgets ----------
# HOMEPAGE_VAR_UPTIMEKUMA_API=
# HOMEPAGE_VAR_VICTORIAMETRICS_API=
